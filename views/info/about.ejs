<%- include('../partials/header', { title: 'About Us - Yatra', activePage: 'about' }) %>

    <main>
        <section class="hero" style="height: 40vh;">
            <div class="hero-content">
                <h1>About Us</h1>
                <p>Your Trusted Travel Partner Since 2024</p>
            </div>
        </section>

        <section class="about-section">
            <div class="about-container">
                <div class="about-content">
                    <h2>Our Story</h2>
                    <p>Founded in 2024, Yatra has grown from a small travel agency to one of India's leading travel platforms. Our journey began with a simple mission: to make travel accessible, enjoyable, and memorable for everyone.</p>
                    
                    <h2>Our Mission</h2>
                    <p>To provide exceptional travel experiences through personalized service, innovative solutions, and a commitment to customer satisfaction.</p>
                    
                    <h2>Our Vision</h2>
                    <p>To become India's most trusted travel partner, setting new standards in the travel industry through technology, service excellence, and sustainable tourism practices.</p>
                </div>

                <div class="achievements">
                    <div class="achievement-card">
                        <i class="fas fa-users"></i>
                        <h3>1M+</h3>
                        <p>Happy Travelers</p>
                    </div>
                    <div class="achievement-card">
                        <i class="fas fa-globe-asia"></i>
                        <h3>100+</h3>
                        <p>Destinations</p>
                    </div>
                    <div class="achievement-card">
                        <i class="fas fa-handshake"></i>
                        <h3>500+</h3>
                        <p>Travel Partners</p>
                    </div>
                    <div class="achievement-card">
                        <i class="fas fa-award"></i>
                        <h3>50+</h3>
                        <p>Awards Won</p>
                    </div>
                </div>

                <div class="team-section">
                    <h2>Our Leadership Team</h2>
                    <div class="team-grid">
                        <div class="team-member">
                            <img src="https://loremflickr.com/150/150/professional,man?random=1" alt="CEO">
                            <h3>John Doe</h3>
                            <p>CEO & Founder</p>
                        </div>
                        <div class="team-member">
                            <img src="https://loremflickr.com/150/150/professional,woman?random=2" alt="COO">
                            <h3>Jane Smith</h3>
                            <p>Chief Operations Officer</p>
                        </div>
                        <div class="team-member">
                            <img src="https://loremflickr.com/150/150/professional,man?random=3" alt="CTO">
                            <h3>Mike Johnson</h3>
                            <p>Chief Technology Officer</p>
                        </div>
                    </div>
                </div>
            </div>
        </section>
    </main>

<%- include('../partials/footer') %>
